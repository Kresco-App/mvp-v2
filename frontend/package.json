{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "validate:production-env": "node scripts/validate-production-env.mjs",
    "test:e2e": "playwright test",
    "test:e2e:integration": "playwright test --config playwright.integration.config.ts",
    "test:e2e:install": "playwright install chromium",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build && npm run test:e2e && npm run test:e2e:integration"
  },
  "dependencies": {
    "@radix-ui/react-slider": "^1.3.6",
