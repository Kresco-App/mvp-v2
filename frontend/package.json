{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=text-summary --coverage.reporter=lcov",
    "validate:production-env": "node scripts/validate-production-env.mjs",
    "check:production-demo-surface": "node scripts/check-production-demo-surface.mjs",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:integration": "node scripts/build-integration.mjs && playwright test --config playwright.integration.config.ts",
    "test:e2e:install": "playwright install chromium",
    "audit:csp-styles": "node scripts/audit-csp-styles.mjs",
    "ci": "npm run lint && npm run audit:csp-styles && npm run typecheck && npm run test:coverage && npm run test:e2e && npm run test:e2e:integration"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-slider": "^1.3.6",
    "ably": "^2.21.0",
    "axios": "^1.16.1",
    "clsx": "^2.1.1",
    "d3-array": "^3.2.4",
    "d3-ease": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-transition": "^3.0.1",
    "framer-motion": "^12.35.1",
    "isomorphic-dompurify": "^3.14.0",
    "katex": "^0.16.37",
    "lucide-react": "^0.577.0",
    "next": "^16.2.6",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.4.1",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@next/env": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@types/d3-array": "^3.2.2",
    "@types/d3-ease": "^3.0.2",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-transition": "^3.0.9",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "8.5.15",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
