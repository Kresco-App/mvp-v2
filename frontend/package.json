    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "es-toolkit": "^1.46.1",
    "framer-motion": "^12.35.1",
    "isomorphic-dompurify": "^3.14.0",
    "katex": "^0.16.37",
    "lucide-react": "^0.577.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.4.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
