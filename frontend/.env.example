# Keep browser API calls same-origin so subdomain cookie auth works locally.
# Next rewrites /api and /media to KRESCO_LOCAL_BACKEND_ORIGIN in development.
NEXT_PUBLIC_API_BASE_URL=/api/
KRESCO_LOCAL_BACKEND_ORIGIN=http://127.0.0.1:8000
# Use kresco.test with hosts-file entries for the closest production mirror.
# If you do not want hosts-file edits, use http://kresco.lvh.me:3000 and kresco.lvh.me.
NEXT_PUBLIC_SITE_URL=http://kresco.test:3000
NEXT_PUBLIC_AUTH_COOKIE_DOMAIN=kresco.test
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIRESTORE_DATABASE=(default)
NEXT_PUBLIC_REALTIME_PROVIDER=firestore
NEXT_PUBLIC_RELEASE_SHA=development
