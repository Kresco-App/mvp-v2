  Wand2,
} from 'lucide-react'
import api from '@/lib/axios'
import AuthGuard from '@/components/AuthGuard'

type CrudActions = {
  create: boolean
  read: boolean
  update: boolean
  delete: boolean
}

type CrudCatalogItem = {
  domain: string
  slug: string
  name: string
  name_plural: string
  model: string
  admin_url: string
  actions: CrudActions
}

type AdminOverview = {
  generated_at: string
  totals: Record<string, number>
  content_status: Record<string, Record<string, number>>
  access_billing: Record<string, any>
  ops_readiness: Record<string, any>
