                        </g>
                        <g transform="translate(190, 100)">
                             <circle r="4" fill="#cbd5e1" /> {/* Common Terminal */}
                        </g>
                        
                        {/* Switch Arm (Animated) */}
                        <motion.line 
                            x1="190" y1="100"
                            x2="140" y2={isCharging ? 60 : 140}
                            stroke="white" strokeWidth="4" strokeLinecap="round"
                            animate={{ x2: 140, y2: isCharging ? 60 : 140 }}
