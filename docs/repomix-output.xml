      <b className={`${tone === 'orange' ? 'bg-[#ffb31a]' : 'bg-[#3d32d8]'} kresco-progress-fill block h-full rounded-[inherit]`} style={{ width: `${safeValue}%` }} />
    </span>
  )
}
