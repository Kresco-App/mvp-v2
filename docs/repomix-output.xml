                            {showEnergy && (
                                <ReferenceDot x={time} y={currentValues.energy} yAxisId="left" r={4} fill="#eab308" stroke="white" strokeWidth={2} />
                            )}

                        </LineChart>
                    </ResponsiveContainer>
                </div>
             </div>
         </div>
      </div>

      <style>{`
        @keyframes flow {
            to { stroke-dashoffset: -18; }
