                                ? (opt.correct ? 'border-emerald-500 bg-emerald-50 text-emerald-800' : 'border-rose-500 bg-rose-50 text-rose-800')
                                : 'border-slate-100 hover:border-purple-200 hover:bg-purple-50 text-slate-600'
                            } `}
                    >
                        <span>{opt.label}</span>
                        {choice === opt.id && (
