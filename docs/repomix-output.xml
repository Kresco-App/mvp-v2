        >
            <sup>4</sup>He
        </motion.div>

        {/* Energy Waves */}
        <motion.div 
            initial={{ opacity: 0, scale: 1 }}
            animate={{ opacity: [0, 0.5, 0], scale: 3 }}
            transition={{ duration: 1, delay: 1.5, repeat: 1 }}
            className="absolute w-20 h-20 border-2 border-yellow-400 rounded-full z-0"
        />
    </div>
);
