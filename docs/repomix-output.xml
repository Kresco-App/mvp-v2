.text-slate-500 { color: #71717b !important; }
.text-slate-600 { color: #52525c !important; }

/* Hover states */
.hover\:bg-slate-950:hover { background-color: #f4f4f6 !important; }
.hover\:bg-slate-900:hover { background-color: #f4f4f5 !important; }
.hover\:bg-slate-800:hover { background-color: #e4e4e7 !important; }
.hover\:bg-slate-950:hover.hover\:text-white:hover,
.hover\:bg-slate-900:hover.hover\:text-white:hover,
.hover\:bg-slate-800:hover.hover\:text-white:hover {
  color: #18181b;
}

/* Dividers */
.divide-slate-800 > * + * { border-color: #e4e4e7 !important; }

/* Focus rings */
.ring-slate-800 { --tw-ring-color: #e4e4e7 !important; }

/* Completion and progress states */
.bg-green-900\/20 { background-color: rgba(22,163,74,0.06) !important; }
.bg-green-900 { background-color: #dcfce7 !important; }
.bg-indigo-900 { background-color: #edf1ff !important; }
.bg-indigo-500\/10 { background-color: #edf1ff !important; }
.border-indigo-500\/20 { border-color: rgba(99,102,241,0.3) !important; }
.text-indigo-300 { color: #4f46e5 !important; }
.text-indigo-400 { color: #4f46e5 !important; }
.bg-indigo-500\/20 { background-color: #edf1ff !important; }
.bg-indigo-600\/20 { background-color: #edf1ff !important; }
.bg-indigo-600\/30 { background-color: #e0e7ff !important; }
.text-green-400 { color: #16a34a !important; }
.text-green-500 { color: #16a34a !important; }
.border-green-500\/20 { border-color: rgba(22,163,74,0.3) !important; }
.bg-indigo-600\/10 { background-color: #edf1ff !important; }
.text-slate-500.text-indigo-600 { color: #4338ca !important; }

/* Opacity-variant missing overrides (watch page / sidebar) */
.bg-slate-950\/30 { background-color: rgba(241,245,249,0.6) !important; }
.bg-slate-950\/50 { background-color: rgba(241,245,249,0.7) !important; }
.border-slate-800\/50 { border-color: rgba(228,228,231,0.8) !important; }
.border-slate-800\/60 { border-color: rgba(228,228,231,0.9) !important; }
.hover\:bg-slate-800\/40:hover { background-color: rgba(241,245,249,0.8) !important; }
.hover\:bg-slate-800\/50:hover { background-color: rgba(241,245,249,0.9) !important; }

/* kresco brand */
.bg-kresco\/10 { background-color: #edf1ff !important; }
.text-kresco { color: #453dee !important; }

/* Shadows */
.shadow-2xl,
.shadow-xl,
.shadow-lg,
.shadow-md,
.shadow-sm { --tw-shadow-color: rgb(15 23 42 / 0.08); }

/* ─── Scrollbar ────────────────────────────────────────────────── */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: #d4d4d8; border-radius: 99px; }
::-webkit-scrollbar-thumb:hover { background: #a1a1aa; }

/* ─── Utility classes using CSS vars ───────────────────────────── */
.card {
  background: var(--surface-card);
  border: 1px solid var(--border);
  border-radius: 16px;
  box-shadow: 0 4px 0 rgba(24, 24, 27, 0.12);
}

.card-hover {
  background: var(--surface-card);
  border: 1px solid var(--border);
  border-radius: 16px;
  box-shadow: 0 4px 0 rgba(24, 24, 27, 0.12);
  transition: box-shadow 150ms, border-color 150ms, transform 150ms;
}
.card-hover:hover {
  box-shadow: 0 6px 0 rgba(69,61,238,0.18), 0 8px 22px rgba(24,24,27,0.08);
  border-color: var(--primary);
  transform: translateY(-1px);
}

.kresco-shell {
  width: min(100%, 1440px);
  margin: 0 auto;
  padding: 34px 28px 48px;
}

.kresco-dashboard-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 350px;
  gap: 34px;
  align-items: start;
}

.kresco-sidebar {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.kresco-subject-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 18px;
}

.kresco-lesson-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
  gap: 18px;
}

.kresco-control {
  background: var(--surface-hover);
  border: 1px solid transparent;
  border-radius: 12px;
  color: var(--text-primary);
  font-size: 13px;
  outline: none;
  transition: border-color 150ms, box-shadow 150ms, background 150ms;
}

.kresco-control:focus {
  background: var(--surface-card);
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(69,61,238,0.12);
}

@media (max-width: 1080px) {
  .kresco-dashboard-grid {
    grid-template-columns: 1fr;
  }

  .kresco-sidebar {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }
}

@media (max-width: 720px) {
  .kresco-shell {
    padding: 22px 16px 36px;
  }

  .kresco-subject-grid,
  .kresco-lesson-grid {
    grid-template-columns: 1fr;
  }
}

.text-page-primary   { color: var(--text-primary); }
.text-page-secondary { color: var(--text-secondary); }
.text-page-tertiary  { color: var(--text-tertiary); }
.surface-page  { background: var(--surface-page); }
.surface-card  { background: var(--surface-card); }
.border-theme  { border-color: var(--border); }

/* ─── Level / XP badge ─────────────────────────────────────────── */
.xp-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 10px;
  border-radius: 99px;
  font-size: 11px;
  font-weight: 700;
  background: linear-gradient(135deg, #f59e0b, #f97316);
  color: #ffffff;
  letter-spacing: 0.02em;
}

.streak-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 10px;
  border-radius: 99px;
  font-size: 11px;
  font-weight: 700;
  background: linear-gradient(135deg, #f97316, #ef4444);
  color: #ffffff;
}

/* ─── Section progress path ───────────────────────────────────── */
.section-locked {
  opacity: 0.55;
  cursor: default;
  pointer-events: none;
}

.section-locked-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to right, transparent 70%, var(--surface-card));
  pointer-events: none;
}

/* ─── Notification dot ─────────────────────────────────────────── */
.notif-dot {
  position: absolute;
  top: 6px;
  right: 6px;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #ef4444;
  border: 2px solid var(--surface-card);
}

/* ─── Animations ────────────────────────────────────────────────── */
.animate-fade-in { animation: fadeIn 200ms ease both; }
.kresco-enter {
  animation: krescoRise 360ms cubic-bezier(.2,.8,.2,1) both;
}
.kresco-progress-fill {
  transform-origin: left center;
  animation: krescoScaleX 560ms cubic-bezier(.2,.8,.2,1) both;
  transition: width 420ms cubic-bezier(.2,.8,.2,1), background-color 180ms ease;
}
.kresco-hover-lift {
  transition:
    transform 180ms cubic-bezier(.2,.8,.2,1),
    border-color 180ms ease,
    box-shadow 180ms ease,
    background-color 180ms ease,
    color 180ms ease,
    opacity 180ms ease;
}
.kresco-hover-lift:hover {
  transform: translateY(-2px);
}
.kresco-soft-pulse {
  animation: krescoSoftPulse 2400ms ease-in-out infinite;
}
.kresco-skeleton {
  position: relative;
  overflow: hidden;
  background: #f1f2f5;
}
.kresco-skeleton::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,.7) 48%, transparent 100%);
  background-size: 220% 100%;
  animation: krescoShimmer 1800ms ease-in-out infinite;
  opacity: .55;
}
.kresco-skeleton-media {
  background: #f7f8fb;
}
.kresco-skeleton-media::after {
  opacity: .28;
}
.kresco-skeleton-accent {
  background: #e2e5f7;
}
.kresco-skeleton-cta {
  background: #e8ebf5;
}
.kresco-skeleton-card {
  border-color: #eceef2 !important;
  box-shadow: 0 3px 0 rgba(24,24,27,.08) !important;
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 1ms !important;
    animation-iteration-count: 1 !important;
    scroll-behavior: auto !important;
    transition-duration: 1ms !important;
  }
}

/* Figma v1 redesign layer */
:root {
  --figma-primary: #3a2fd3;
  --figma-primary-soft: #eef2ff;
  --figma-secondary: #f5900b;
  --figma-blue: #29aee4;
  --figma-page: #f8f9fc;
  --figma-card: #ffffff;
  --figma-border: #e4e4e7;
  --figma-muted: #71717b;
  --figma-text: #3f3f46;
}

.figma-app {
  --figma-shell-width: 1504px;
  --figma-shell-gutter: 32px;
  --figma-main-column: 1077px;
  --figma-sidebar-width: 351px;
  --figma-sidebar-gap: 12px;
  min-height: 100vh;
  font-family: var(--font-rounded), system-ui, -apple-system, sans-serif;
  background: #ffffff;
  color: var(--figma-text);
}

.figma-app * {
  font-family: inherit;
}

.figma-container {
  width: min(100%, var(--figma-shell-width));
  margin: 0 auto;
  padding: 28px var(--figma-shell-gutter) 52px;
}

.figma-home-container {
  width: min(100%, var(--figma-shell-width));
  margin: 0 auto;
  padding: 20px var(--figma-shell-gutter) 56px;
}

.figma-courses-container {
  width: min(100%, var(--figma-shell-width));
  margin: 0 auto;
  padding: 0 var(--figma-shell-gutter) 56px;
}

.figma-home-grid,
.figma-courses-grid,
.figma-dashboard-grid {
  display: grid;
  grid-template-columns: minmax(0, var(--figma-main-column)) var(--figma-sidebar-width);
  gap: var(--figma-sidebar-gap);
  align-items: start;
}

.figma-card {
  background: var(--figma-card);
  border: 2px solid var(--figma-border);
  border-radius: 16px;
  box-shadow: 0 14px 35px rgba(24, 24, 27, 0.06);
}

.figma-card-soft {
  background: var(--figma-card);
  border: 1px solid #f1f1f3;
  border-radius: 16px;
  box-shadow: 0 18px 40px rgba(24, 24, 27, 0.08);
}

.figma-title {
  color: #3f3f46;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 1.12;
}

.figma-subtle {
  color: var(--figma-muted);
  font-weight: 700;
}

.figma-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 44px;
  padding: 0 18px;
  border: 0;
  border-radius: 14px;
  background: var(--figma-primary);
  color: #ffffff;
  font-size: 13px;
  font-weight: 900;
  text-decoration: none;
  box-shadow: 0 8px 18px rgba(58, 47, 211, 0.18);
