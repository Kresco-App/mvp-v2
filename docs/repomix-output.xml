// --- Shared Components ---
const ExerciseCard = ({ title, difficulty, children }: { title: string, difficulty: string, children: React.ReactNode }) => (
    <div className="bg-white rounded-3xl shadow-xl border border-slate-200 overflow-hidden mb-8">
