        user_id=user.id,
        event_type=f"{item.item_type}_completed",
        target_type="topic_item",
        target_id=item.id,
        topic_id=item.topic_id,
        topic_item_id=item.id,
        metadata_json={"score": body.score, "watched_seconds": body.watched_seconds},
    ))
