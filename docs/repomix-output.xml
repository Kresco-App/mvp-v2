      </div>

      {/* Progress Bar */}
      {isPlaying && (
          <div className="absolute bottom-0 left-0 w-full h-1.5 bg-slate-100">
            <motion.div 
                initial={{ width: "0%" }}
                animate={{ width: "100%" }}
                transition={{ duration: 5, ease: "linear", repeat: Infinity }}
                className="h-full bg-[#fbbf24]"
            />
          </div>
      )}
    </div>
  );
};
