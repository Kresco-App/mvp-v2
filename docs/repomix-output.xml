  subject_id: number
  subject_title: string
  title: string
  year: number
  session: string
  statement_url: string
  can_access?: boolean
  locked_reason?: string
  access_reason?: string
  required_tier?: string
  required_feature_key?: string
  required_subject_id?: number | null
  problems: ExamProblem[]
