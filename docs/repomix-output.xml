                            {/* Plates */}
                            <line x1="-25" y1="-30" x2="25" y2="-30" stroke="white" strokeWidth="4" strokeLinecap="round" />
                            <line x1="-25" y1="30" x2="25" y2="30" stroke="white" strokeWidth="4" strokeLinecap="round" />
                            
