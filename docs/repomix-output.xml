    type: "Bêta Moins (β⁻)",
    prompt: "Le Césium-135 se désintègre en Baryum. Équilibrez la réaction.",
    equation: {
      parent: { A: 135, Z: 55, Sym: 'Cs' },
      daughter: { A: '?', Z: '?', Sym: 'Ba' }, // Answers: 135, 56
