                            {/* Points of interest */}
                            {/* Fe-56 (Peak) */}
                            <circle cx="100" cy="30" r="4" fill="#ef4444" />
                            <text x="100" y="20" fontSize="10" textAnchor="middle" fill="#ef4444">Fe-56 (~8.8 MeV)</text>

                            {/* U-235 (Heavy) */}
                            <circle cx="340" cy="55" r="4" fill="#ef4444" />
