                             <path d="M -45 -30 L -15 -30 L 0 -15" fill="none" stroke="#475569" strokeWidth="1" strokeDasharray="2 2"/>
                             <path d="M -45 30 L -15 30 L 0 15" fill="none" stroke="#475569" strokeWidth="1" strokeDasharray="2 2"/>
