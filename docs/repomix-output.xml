    handleGoogleCredential: (response: any) => void
  }
}

type Step = 'auth' | 'niveau' | 'filiere'
type AuthMode = 'options' | 'login' | 'signup' | 'verify-pending' | 'forgot' | 'forgot-sent'

const NIVEAUX = [
  { id: '1bac', label: '1ère Bac' },
