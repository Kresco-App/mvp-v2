def hash_password(plain: str) -> str:
    salt = b"kresco-local-seed"
    dk = hashlib.pbkdf2_hmac("sha256", plain.encode(), salt, 260_000)
    return salt.hex() + ":" + dk.hex()


def slugify(value: str) -> str:
    return (
        value.lower()
        .replace(" ", "-")
        .replace("'", "")
        .replace("é", "e")
        .replace("è", "e")
        .replace("ê", "e")
        .replace("à", "a")
        .replace("ç", "c")
    )


