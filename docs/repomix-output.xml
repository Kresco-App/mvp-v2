  statement: string
  written_solution: string
  written_solution_url: string
  difficulty: string
  concept_slugs: string[]
  video_resource?: { id: number; title: string; provider: string; provider_resource_id: string } | null
  can_access?: boolean
  locked_reason?: string
  access_reason?: string
