  media?: AnimatedMedia
  hint?: string
  metadata?: Record<string, AnimatedJsonValue>
}

export type AnimatedSimulatorControl = {
  id: string
  label: string
  kind: 'slider' | 'stepper' | 'toggle' | 'select' | 'radio' | 'number'
