{
    "production": {
        "app_function": "app_handler.application",
        "project_name": "kresco",
        "runtime": "python3.11",
        "s3_bucket": "kresco-zappa-367182071147",
        "aws_region": "eu-north-1",
        "environment_variables": {
            "KRESCO_ENV": "production",
            "DATABASE_URL": "__SET_IN_AWS_SECRETS__",
            "DATABASE_CONNECTION_STRATEGY": "rds_proxy",
            "PGSSLROOTCERT": "certs/rds-global-bundle.pem",
            "JWT_SECRET_KEY": "__SET_IN_AWS_SECRETS__",
            "JWT_ALGORITHM": "HS256",
            "JWT_EXPIRE_MINUTES": "10080",
            "DEBUG": "false",
            "GOOGLE_CLIENT_ID": "__SET_IN_AWS_SECRETS__",
            "VDOCIPHER_API_SECRET": "__SET_IN_AWS_SECRETS__",
            "VDOCIPHER_API_BASE_URL": "__SET_IN_AWS_SECRETS__",
            "VDOCIPHER_LIVE_CREATE_URL": "__SET_IN_AWS_SECRETS__",
            "CORS_ALLOWED_ORIGINS": "__SET_IN_AWS_SECRETS__",
            "CORS_ALLOW_ORIGIN_REGEX": "",
            "FRONTEND_URL": "__SET_IN_AWS_SECRETS__",
            "STRIPE_PK": "",
            "STRIPE_SK": "__SET_IN_AWS_SECRETS__",
            "STRIPE_PRODUCT_ID": "__SET_IN_AWS_SECRETS__",
            "STRIPE_WEBHOOK_SECRET": "__SET_IN_AWS_SECRETS__",
            "RESEND_API_KEY": "__SET_IN_AWS_SECRETS__",
            "ABLY_API_KEY": "__SET_IN_AWS_SECRETS__",
            "REALTIME_OUTBOX_SECRET": "__SET_IN_AWS_SECRETS__",
            "MEDIA_STORAGE_BACKEND": "s3",
            "MEDIA_S3_BUCKET": "__SET_IN_AWS_SECRETS__",
            "MEDIA_S3_REGION": "eu-north-1",
            "MEDIA_S3_PREFIX": "production",
            "MEDIA_S3_PRESIGN_TTL_SECONDS": "300",
            "MEDIA_PROFILE_QUOTA_BYTES": "10485760",
            "MEDIA_CHAT_CONVERSATION_QUOTA_BYTES": "52428800",
            "MEDIA_S3_LIFECYCLE_EXPIRATION_DAYS": "365"
        },
        "events": [
            {
                "function": "app.scheduled.process_realtime_outbox_event",
                "expression": "rate(1 minute)"
            }
        ],
        "cors": true,
        "timeout_seconds": 45,
        "memory_size": 1024,
        "manage_roles": true,
        "apigateway_enabled": true,
        "slim_handler": true,
        "keep_warm": true
    },
