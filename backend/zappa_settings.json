{
    "production": {
        "app_function": "app_handler.application",
        "project_name": "kresco",
        "runtime": "python3.11",
        "s3_bucket": "kresco-zappa-eu-west-3-367182071147",
        "aws_region": "eu-west-3",
        "environment_variables": {
            "KRESCO_ENV": "production",
            "KRESCO_RELEASE_SHA": "__SET_IN_AWS_SECRETS__",
            "KRESCO_RUNTIME_SECRET_ID": "__SET_IN_AWS_SECRETS__",
            "DATABASE_CONNECTION_STRATEGY": "rds_proxy",
            "PGSSLROOTCERT": "certifi",
            "JWT_ALGORITHM": "HS256",
            "JWT_EXPIRE_MINUTES": "10080",
            "DEBUG": "false",
            "CORS_ALLOWED_ORIGINS": "__SET_IN_AWS_SECRETS__",
            "CORS_ALLOW_ORIGIN_REGEX": "",
            "FRONTEND_URL": "__SET_IN_AWS_SECRETS__",
            "STRIPE_PK": "",
            "MEDIA_STORAGE_BACKEND": "s3",
            "MEDIA_S3_REGION": "eu-west-3",
            "MEDIA_S3_PREFIX": "production",
            "MEDIA_S3_PRESIGN_TTL_SECONDS": "300",
            "MEDIA_PROFILE_QUOTA_BYTES": "10485760",
            "MEDIA_CHAT_CONVERSATION_QUOTA_BYTES": "52428800",
            "MEDIA_S3_LIFECYCLE_EXPIRATION_DAYS": "365"
        },
        "extra_permissions": [
            {
                "Effect": "Allow",
                "Action": [
                    "secretsmanager:GetSecretValue"
                ],
                "Resource": "__SET_IN_AWS_SECRETS__"
            }
        ],
        "vpc_config": {
            "SubnetIds": "__SET_IN_AWS_SECRETS__",
            "SecurityGroupIds": "__SET_IN_AWS_SECRETS__"
        },
        "events": [
            {
                "function": "app.scheduled.process_realtime_outbox_event",
                "expression": "rate(1 minute)"
            }
        ],
        "cors": true,
        "timeout_seconds": 45,
        "memory_size": 1024,
        "manage_roles": true,
        "apigateway_enabled": true,
        "slim_handler": true,
        "keep_warm": true,
        "touch": false
    },
    "staging": {
        "app_function": "app_handler.application",
        "project_name": "kresco-staging",
